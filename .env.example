# 1) Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# 2) Admin login (seed uses these)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-this-password"

# 3) Auth token secret (must be long & random)
JWT_SECRET="replace-with-a-long-random-string"

# 4) Optional: Cloudinary for uploads (recommended for production)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
